# Copy this file to .env and fill in your values.
# `source install.sh` creates the required ones for you interactively.

# --- Required ---------------------------------------------------------------
BOT_TOKEN="your-telegram-bot-token"
POSTGRESQL_DATABASE_HOST="localhost"
POSTGRESQL_DATABASE_NAME="musicbot"
POSTGRESQL_DATABASE_USER="musicbot"
POSTGRESQL_DATABASE_PASSWORD="your-db-password"

# --- Optional ---------------------------------------------------------------
# Comma-separated Telegram user IDs allowed to use /stats and /broadcast.
# Leave empty to disable admin commands.
ADMIN_IDS=

# Channel users must join before using the bot (e.g. @mychannel). Leave empty
# to disable. The bot must be an admin of the channel for the check to work.
REQUIRED_CHANNEL=

# How many downloads may run at once (raise on bigger hosts).
MAX_PARALLEL_DOWNLOADS=4

# Skip audio larger than this many bytes (Telegram's bot upload limit is 50 MB).
MAX_AUDIO_FILESIZE=52428800

# On-disk cache cap in bytes (tracks are deleted after sending anyway).
MAX_TRACK_STORAGE_SIZE=2147483648

# Max cached (query -> file_id) rows before the oldest are dropped.
CACHE_MAX_ENTRIES=5000

# Set to 1 to also write rotating log files under logs/ (off keeps disk clean).
LOG_TO_FILE=0

# Set to 1 to transcode to MP3 (needs FFmpeg; CPU-heavy). Off sends .m4a.
CONVERT_TO_MP3=0

# Path to an FFmpeg binary (only used when CONVERT_TO_MP3=1).
FFMPEG_LOCATION=

# Override the YouTube player clients yt-dlp uses (comma-separated). Leave empty
# to use yt-dlp's defaults.
YTDLP_PLAYER_CLIENTS=

# Path to a Netscape-format YouTube cookies file. With the PO-token provider
# below you normally DON'T need cookies; leave empty for a cookieless setup.
YTDLP_COOKIEFILE=

# --- Search & download source ----------------------------------------------
# Search runs on YouTube Music (accurate song metadata) and the exact match is
# downloaded from YouTube; SoundCloud is only a fallback source.

# How many search results to show in the pick-a-track menu.
MUSIC_SEARCH_LIMIT=20

# When a YouTube download fails, try SoundCloud for the same track (1=on, 0=off).
SOUNDCLOUD_FALLBACK=1

# bgutil PO-token provider URL — lets yt-dlp fetch YouTube audio WITHOUT cookies
# (answers the "Sign in to confirm you're not a bot" challenge). Leave empty for
# the standard local Docker setup (the plugin auto-detects http://127.0.0.1:4416).
# Set this only if you run the provider on a different host/port.
POT_PROVIDER_BASE_URL=
